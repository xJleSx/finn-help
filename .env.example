# Database URL (default: SQLite)
DATABASE_URL=sqlite:///data/finn.db

# Telegram Bot token (phase 3+)
# TELEGRAM_BOT_TOKEN=

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
