# === НЕ КОММИТИТЬ ЭТОТ ФАЙЛ ===
# Actual values in .env (gitignored)
# Copy: cp .env.example .env

# === LLM ===
# Groq API (free: console.groq.com)
# GROQ_API_ID=your-groq-api-key
# Ollama fallback
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b

# === Tinkoff Invest API ===
# TINKOFF_TOKEN=your-tinkoff-token
# Use sandbox for testing (true/false)
# TINKOFF_SANDBOX=true

# === Автотрейдинг ===
# ENABLE_TRADING=true — включить исполнение ордеров в AUTO mode.
# По умолчанию false: все операции в DRY_RUN.
# MAX_TRADES_PER_DAY=5

# === База данных ===
# PostgreSQL (рекомендуется для продакшена)
DATABASE_URL=postgresql://finn:finn@localhost:5432/finn
# SQLite (для локальной разработки, закомментировать PostgreSQL)
# DATABASE_URL=sqlite:///data/finn.db

# === Telegram Bot (phase 3+) ===
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# === Rate Limits ===
# API rate limit per minute (0 = unlimited)
# RATE_LIMIT_PER_MINUTE=60

# === Логирование ===
LOG_LEVEL=INFO

# === CORS ===
# Разрешённые origins (через запятую). * только для dev, без credentials.
# CORS_ORIGINS=http://localhost:3000
# CORS_CREDENTIALS=true

# === MOEX ===
# MOEX_ISS_URL=https://iss.moex.com/iss
# CBR_URL=https://www.cbr.ru/scripts/XML_daily.asp

# === WolframAlpha API ===
# Бесплатно: 2000 запросов/мес для некоммерческого использования
# Получить AppID: https://developer.wolframalpha.com
# WOLFRAM_APP_ID=your-wolfram-app-id
# WOLFRAM_ENABLED=true
